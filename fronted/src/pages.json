{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u--(.*)": "uview-plus/components/u-$1/u-$1.vue",
      "^up-(.*)": "uview-plus/components/u-$1/u-$1.vue",
      "^u-([^-].*)": "uview-plus/components/u-$1/u-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/splash/splash",
      "style": {
        "navigationStyle": "custom",
        "disableScroll": true
      }
    },
    {
      "path": "pages/login/login",
      "style": {
        "navigationBarTitleText": "登录",
        "navigationBarBackgroundColor": "#ff7000",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/register/register",
      "style": {
        "navigationBarTitleText": "注册",
        "navigationBarBackgroundColor": "#ff7000",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "课程列表",
        "navigationBarBackgroundColor": "#ff7000",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/progress/progress",
      "style": {
        "navigationBarTitleText": "学习进度",
        "navigationBarBackgroundColor": "#ff7000",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/wrong/wrong",
      "style": {
        "navigationBarTitleText": "错题集",
        "navigationBarBackgroundColor": "#ff7000",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/wrong/detail",
      "style": {
        "navigationBarTitleText": "错题详情",
        "navigationBarBackgroundColor": "#ff7000",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/mine/mine",
      "style": {
        "navigationBarTitleText": "我的",
        "navigationBarBackgroundColor": "#ff7000",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/video/play",
      "style": {
        "navigationBarTitleText": "课程学习",
        "navigationBarBackgroundColor": "#ff7000",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/quiz/quiz",
      "style": {
        "navigationBarTitleText": "课堂测验",
        "navigationBarBackgroundColor": "#ff7000",
        "navigationBarTextStyle": "white"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "狐灵商学",
    "navigationBarBackgroundColor": "#ff7000",
    "backgroundColor": "#f6f7f8"
  },
  "tabBar": {
    "color": "#909399",
    "selectedColor": "#ff7000",
    "backgroundColor": "#ffffff",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "课程列表",
        "iconPath": "static/tab-list.png",
        "selectedIconPath": "static/tab-list-active.png"
      },
      {
        "pagePath": "pages/progress/progress",
        "text": "学习进度",
        "iconPath": "static/tab-progress.png",
        "selectedIconPath": "static/tab-progress-active.png"
      },
      {
        "pagePath": "pages/wrong/wrong",
        "text": "错题集",
        "iconPath": "static/tab-wrong.png",
        "selectedIconPath": "static/tab-wrong-active.png"
      },
      {
        "pagePath": "pages/mine/mine",
        "text": "我的",
        "iconPath": "static/tab-mine.png",
        "selectedIconPath": "static/tab-mine-active.png"
      }
    ]
  }
}
