# 依赖（各子项目）
node_modules/

# 构建产物
dist/
**/dist/
unpackage/

# 根目录 H5 发布拷贝（可由 fronted `build:h5` 再生成，按需保留；若需提交部署目录可删本行）
/h5/

# 环境变量与密钥（示例文件可提交）
.env
.env.*
!.env.example
!**/.env.example

# 日志与调试
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 缓存与临时文件
.cache/
.parcel-cache/
.turbo/
*.tmp
*.temp

# 操作系统
.DS_Store
Thumbs.db
Desktop.ini

# 编辑器与 IDE
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
